# Base URL the Next.js server uses to reach the Python data function.
#
# Local dev (npm run dev): the Python fetcher runs at localhost:8000 via
#   scripts/dev_api.py, and this is the default — you can leave it unset.
# Vercel: the /api/*.py function is on the same domain; VERCEL_URL is used
#   automatically, so you do not need to set this in production.
#
# Override only if you want to point at a remote/alternate data function.
PYTHON_API_BASE_URL=http://localhost:8000

# Optional: enables the "Re-scan" developer-news feature in the HK CRE Risk
# Monitor (app/api/cre-news). Without it, the panel shows topic-page links
# instead of AI-summarized headlines. Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# CRE_NEWS_SEARCH_TOOL=web_search_20250305   # override the web-search tool version

# Daily-snapshot caching (lib/snapshot.ts + app/api/cron/refresh).
# On Vercel, link a Blob store and BLOB_READ_WRITE_TOKEN is set automatically;
# locally, snapshots fall back to .snapshots/ on disk (no token needed).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# CRON_SECRET protects the refresh endpoint; Vercel Cron sends it as a Bearer token.
# REQUIRED on Vercel: without it the refresh endpoint fails closed (503) rather
# than expose an open, expensive job. Optional locally (left open for seeding).
# CRON_SECRET=some-long-random-string
